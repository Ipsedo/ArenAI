{
  "model": "opus",
  "askBeforeRunningTool": false,
  "permissions": {
    "allow": [
      "Read(./*)",
      "Read(./**)",
      "Search(./*)",
      "Grep",
      "Glob",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(clang-format:*)",
      "Bash(cmake:*)",
      "Bash(make:*)",
      "Bash(ctest:*)",
      "Bash(mkdir -p build)",
      "Bash(mkdir -p build && cd build)",
      "Bash(./arenai_core/tests/arenai_core_tests)",
      "Bash(./arenai_view/tests/arenai_view_tests)",
      "Bash(./arenai/.venv/bin/pre-commit run *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh .claude/scripts/run_format.sh",
            "statusMessage": "Running pre-commit format hooks...",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
